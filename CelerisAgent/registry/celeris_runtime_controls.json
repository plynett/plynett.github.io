    {
      "namespace": "design",
      "action": "prepare_linear_structure",
      "panel": "Add Engineered Design Components",
      "html_order": 16,
      "purpose": "Set required linear-structure cross-section parameters and put the runner into start-point selection mode.",
      "html_control_id": "designcomponent_CrestElev-input",
      "calc_constants_property": "designcomponent_CrestElev/designcomponent_CrestWidth/designcomponent_SideSlope",
      "safe_while_running": true,
      "reloads_case": false,
      "response_template": "set up the {structure_label} cross-section: crest elevation {crest_elevation_m} m, crest width {crest_width_m} m, side slope {side_slope}. Right-click the structure start location in Design Mode. When the start point looks correct, tell me the start point is set",
      "arguments": [
        { "name": "structure_label", "type": "string", "required": false },
        { "name": "crest_elevation_m", "type": "number", "required": true },
        { "name": "crest_width_m", "type": "number", "required": true },
        { "name": "side_slope", "type": "number", "required": true }
      ],
      "selection_policy": "Use this command for breakwaters, dunes, seawalls, levees, berms, revetments, and other linear structures only after crest elevation, crest width, and side slope are specified. If any of those three values are missing or malformed, do not emit this command. Answer conversationally with the usable values already supplied, and ask only for missing or malformed values. If no required values are usable, answer: To add a structure, I need crest elevation, crest width, and side slope - for example \"add a breakwater with crest elevation of 1m, crest width of 2 m, and side slope of 1/2\".",
      "examples": [
        "add a breakwater with crest elevation 3 m, crest width 8 m, side slope 0.5",
        "set up a dune, crest elevation 4 m, width 20 m, side slope 0.25"
      ]
    },
